#!/bin/zsh

set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_DIR="$PROJECT_DIR/dev-config"

rm -rf "$CONFIG_DIR/.storage"
rm -f "$CONFIG_DIR/home-assistant_v2.db"
rm -f "$CONFIG_DIR/home-assistant_v2.db-shm"
rm -f "$CONFIG_DIR/home-assistant_v2.db-wal"
rm -f "$CONFIG_DIR/home-assistant.log"
rm -f "$CONFIG_DIR/home-assistant.log.1"

echo "Local Home Assistant state has been reset."
echo "Run ./run-ha to begin fresh onboarding."
